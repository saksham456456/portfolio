# Copy this file to .env.local for local development.
# Never commit real credentials.

# Required for the AI/chat feature.
AI_PROVIDER=openai
AI_MODEL=gpt-4.1-mini
AI_PROVIDER_API_KEY=your_model_provider_api_key_here

# Optional public site URL used for canonical links, metadata, and webhook callbacks.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional analytics integration.
NEXT_PUBLIC_ANALYTICS_KEY=

# Optional email/contact integration.
CONTACT_PROVIDER=resend
CONTACT_API_KEY=
CONTACT_TO_EMAIL=
CONTACT_FROM_EMAIL=

# Optional rate limiting or abuse prevention.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
